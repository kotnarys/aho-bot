# === LLM Provider (OpenRouter) ===
OPENAI_API_KEY=sk-or-v1-your-openrouter-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Рекомендуемые модели (по соотношению цена/качество):
#   google/gemini-2.5-flash       — быстро, дёшево, отличный JSON
#   anthropic/claude-sonnet-4     — высокое качество
#   openai/gpt-4o-mini            — стабильный baseline
#   openai/gpt-5                  — максимальное качество (дорого)
MODEL_NAME=google/gemini-2.5-flash

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === App ===
LOG_LEVEL=INFO
ENVIRONMENT=development
